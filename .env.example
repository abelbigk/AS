NODE_ENV=development
PORT=3000

# JWT auth
JWT_SECRET=replace-with-a-long-random-secret

# Turso/libSQL
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=replace-with-your-turso-token

# Cloudflare R2
R2_ACCOUNT_ID=replace-with-your-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-your-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-your-r2-secret-access-key
R2_BUCKET=replace-with-your-r2-bucket
R2_PUBLIC_URL=https://your-public-r2-url.r2.dev

# Optional OAuth/analytics/forge integrations
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
DATABASE_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
