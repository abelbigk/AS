{
  "name": "as-app",
  "version": "1.0.0",
  "main": "index",
  "type": "module",
  "scripts": {
    "start": "expo start --lan",
    "start:local": "expo start --localhost",
    "start:tunnel": "expo start --tunnel",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "prebuild": "expo prebuild --clean",
    "bundle:android": "node -e \"import('fs').then(fs => fs.mkdirSync('android/app/src/main/assets',{recursive:true}))\" && npx react-native bundle --platform android --dev false --entry-file index.tsx --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/",
    "build:apk-local": "npm run bundle:android && cd android && ./gradlew assembleRelease && cd .."
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@tanstack/react-query": "^5.51.23",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "axios": "^1.7.7",
    "copy-anything": "4.0.5",
    "expo": "^52.0.0",
    "expo-asset": "~11.0.1",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "lucide-react-native": "^1.24.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-image-crop-picker": "^0.41.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-toast-notifications": "^3.4.0",
    "superjson": "^2.2.6",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^20.2.0",
    "@react-native-community/cli-platform-android": "^20.2.0",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.3",
    "typescript": "^5.3.3"
  },
  "private": true
}
